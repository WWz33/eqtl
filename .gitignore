# binary at repo root only
/eqtl
*.o
*.a
*.so

# local scripts (not shipped)
/scripts/

# third_party build products only (sources tracked as submodules)
third_party/htslib/config.mk
third_party/htslib/config.h
third_party/htslib/htslib_static.mk
